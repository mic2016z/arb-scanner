RUST_LOG=info

# Phase 1 infra endpoints
SOLANA_RPC_URL=http://127.0.0.1:8899
YELLOWSTONE_GRPC_ENDPOINT=https://127.0.0.1:10000
YELLOWSTONE_GRPC_X_TOKEN=
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# Phase 2 radar
WATCH_PROGRAMS=raydium,pumpfun
COMMITMENT=processed
TARGET_EVENT_DISCRIMINATORS=initialize_pool,add_liquidity
EVENT_DETECTION_TARGET_MS=50
LOOP_TARGET_MS=200

# Phase 3 risk gates
MIN_POOL_SIZE_SOL=90
REQUIRE_NULL_MINT_AUTHORITY=true
REQUIRE_NULL_FREEZE_AUTHORITY=true
REQUIRE_LP_BURNED=true
BLOCK_TOKEN_2022_TRANSFER_HOOKS=true
BLOCK_FEE_ON_TRANSFER=true

# Phase 4 execution
COMPUTE_UNIT_LIMIT=350000
PRIORITY_FEE_MICRO_LAMPORTS=500000
MIN_TIP_SOL=0.01
MAX_TIP_SOL=0.10

# Phase 5 exits
TAKE_PROFIT_MULTIPLIER=2.0
STOP_LOSS_PCT=0.12
MAX_TRADE_FRACTION=0.02
WALLET_SHARDS=5

# Phase 6 telemetry and halts
MAX_SLOTS_BEHIND=3
ENABLE_CIRCUIT_BREAKER=true
